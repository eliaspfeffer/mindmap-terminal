{
  "name": "mindmap-terminal",
  "version": "0.1.0",
  "description": "Mindmap with embedded terminals — plan and execute in one place",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
